<Page x:Class="ApartmentChain.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ApartmentChain.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Главная страница" IsVisibleChanged="Page_IsVisibleChanged" Background="#D2B48C">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="205"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel x:Name="SortStackPanel" Orientation="Vertical" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Top">
            <TextBlock Text="Фильтры" Style="{StaticResource TextBlockStyle}" HorizontalAlignment="Center" FontWeight="Bold"/>
            <TextBlock Text="Минимальная цена" Style="{StaticResource TextBlockStyle}" />
            <TextBox Name="MinPriceTextBox" ToolTip="Введите минимальную цену для фильтрации в формате 4000,00" Style="{StaticResource TextBoxStyle}" Width="200" Height="30"/>
            <TextBlock Text="Максимальная цена" Style="{StaticResource TextBlockStyle}"/>
            <TextBox Name="MaxPriceTextBox" ToolTip="Введите максимальную цену для фильтрации в формате 4000,00" Style="{StaticResource TextBoxStyle}" Width="200" Height="30"/>
            <Button Content="Применить фильтр" ToolTip="Нажмите для применения фильтрации" Style="{StaticResource ButtonStyle}" Width="190" Margin="0,10"/>
        </StackPanel>

        <ListView Name="ApartList" ScrollViewer.HorizontalScrollBarVisibility="Disabled" Grid.Column="1" BorderThickness="0" Background="Transparent">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="450"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <Border DataContext="{Binding PhotosViewModel}" Grid.Row="0" HorizontalAlignment="Center" Width="500" Margin="5">
                            <Grid>
                                <Image Source="{Binding CurrentPhoto}" Stretch="Fill"/>
                                <Button x:Name="PrevPhotoButton" Content="◀" Command="{Binding PrevPhotoCommand}" HorizontalAlignment="Left" Style="{StaticResource CommandButtonStyle}"/>
                                <Button x:Name="NextPhotoButton" Content="▶" Command="{Binding NextPhotoCommand}" HorizontalAlignment="Right" Style="{StaticResource CommandButtonStyle}"/>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Top" Orientation="Horizontal" Height="30" Width="500">
                            <Rectangle Width="5"/>
                            <TextBlock Text="{Binding Cities}" Style="{StaticResource TextBlockStyle}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Address}" Style="{StaticResource TextBlockStyle}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Building}" Style="{StaticResource TextBlockStyle}" FontWeight="Bold"/>
                        </StackPanel>

                        <Button Name="ToBookButton" Content="Забронировать" ToolTip="Перейти к бронированию" Grid.Row="2" Margin="0,10,0,0" HorizontalAlignment="Left" Style="{StaticResource ButtonStyle}"/>
                        <StackPanel Grid.Row="2" HorizontalAlignment="Right" Margin="0,10,0,0" Orientation="Horizontal">
                            <TextBlock Text="{Binding Price}" Style="{StaticResource TextBlockStyle}" FontWeight="Bold"/>
                            <TextBlock Text=" ₽ в сутки" Style="{StaticResource TextBlockStyle}" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
        </ListView>
    </Grid>
</Page>