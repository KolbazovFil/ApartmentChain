<Page x:Class="ApartmentChain.Pages.AboutAppPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ApartmentChain.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Страница с информацией о приложении">

    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        
        <Grid Width="800">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="100"/>
                <RowDefinition Height="150"/>
                <RowDefinition Height="140"/>
            </Grid.RowDefinitions>
            
            <TextBlock Text="О приложении" Grid.ColumnSpan="2" Grid.Row="0" Style="{StaticResource HeaderTextBlockStyle}"/>
            <TextBlock Text="Приложение ApartmentChain всероссийская сеть апартартаментов в аренду, созданная Колбазовым Филиппом Дионисовичем в 2026 году." 
                       Grid.Column="0" Grid.Row="1" TextWrapping="Wrap" TextAlignment="Justify" HorizontalAlignment="Left" Style="{StaticResource TextBlockStyle}"/>
            
            <TextBlock Text="Сеть имеет собственные технические и операционные стандарты, которые сочетают высокие российские требования и специфику сегмента сдачи апартаментов. Апартартаменты сочетают в себе гостиничную и жилую составляющие." 
                       Grid.Column="1" Grid.Row="2" TextAlignment="Justify" TextWrapping="Wrap" HorizontalAlignment="Left" Style="{StaticResource TextBlockStyle}"/>

            <TextBlock Name="CountDeal" Grid.Row="3" Grid.Column="0" FontSize="18" FontWeight="Bold" HorizontalAlignment="Left" Style="{StaticResource TextBlockStyle}"/>

            <TextBlock Text="Год создания сети: 2026" Grid.Row="3" Grid.Column="1" FontSize="18" FontWeight="Bold" HorizontalAlignment="Left" Style="{StaticResource TextBlockStyle}"/>
        </Grid>
    </ScrollViewer>
</Page>
