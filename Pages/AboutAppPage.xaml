<Page x:Class="ApartmentChain.Pages.AboutAppPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ApartmentChain.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Страница о приложении">

    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <Grid Width="800">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="100"/>
                <RowDefinition Height="150"/>
                <RowDefinition Height="140"/>
            </Grid.RowDefinitions>
            <TextBlock Text="О приложении" FontWeight="Bold" Grid.ColumnSpan="2" Grid.Row="0" Style="{StaticResource TextBlockStyle}"/>
            <TextBlock Text="Приложение # всероссийская сеть апартартаментов в аренду, созданная Колбазовым Филиппом Дионисовичом в 2026 году." TextWrapping="Wrap" TextAlignment="Justify" Grid.Column="0" Grid.Row="1" Style="{StaticResource TextBlockStyle}"/>
            <TextBlock Text="Сеть имеет собственные технические и операционные стандарты, которые сочетают высокие российские требования и специфику сегмента сдачи апартаментов. Апартартаменты сочетают в себе гостиничную и жилую составляющие." Grid.Column="1" Grid.Row="2" TextAlignment="Justify" TextWrapping="Wrap" Style="{StaticResource TextBlockStyle}"/>
            <TextBlock Name="CountDeal" FontWeight="Bold" Grid.Row="3" Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Left" Style="{StaticResource TextBlockStyle}"/>
        </Grid>
    </ScrollViewer>
</Page>
