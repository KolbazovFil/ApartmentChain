<Page x:Class="ApartmentChain.Pages.BookingManagmentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ApartmentChain.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Страница управления бронированиями" IsVisibleChanged="Page_IsVisibleChanged">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Мои бронирования" Grid.Row="0" FontWeight="Bold" Style="{StaticResource TextBlockStyle }"/>

        <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Center">
            <TextBlock Text="Фильтр по статусу:" Style="{StaticResource TextBlockStyle}"/>
            <ComboBox Name="FilterStatusComboBox" Width="150" Margin="5,0,0,0" SelectionChanged="FilterStatusComboBox_SelectionChanged"/>
            <TextBox x:Name="SearchTextBox" ToolTip="Поиск по городу и апартаментов" Margin="10,0,0,0" Style="{StaticResource TextBoxStyle}" TextChanged="SearchTextBox_TextChanged"/>
        </StackPanel>

        <DataGrid x:Name="BookingsDataGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ID}"/>
                <DataGridTextColumn Header="Город" Binding="{Binding Cities}"/>
                <DataGridTextColumn Header="Апартаменты" Binding="{Binding ApartmentName}"/>
                <DataGridTextColumn Header="Дата заезда" Binding="{Binding Arrival}"/>
                <DataGridTextColumn Header="Дата выезда" Binding="{Binding Departure}"/>
                <DataGridTextColumn Header="Общая стоимость" Binding="{Binding TotalCost}"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding BookingStatus}"/>
                <DataGridTemplateColumn Header="Действия" MinWidth="300">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="Редактировать" Height="30" Width="140" Style="{StaticResource ButtonStyle}" Click="EditBooking_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        <Button x:Name="CancelButton" Grid.Row="3" Content="Отмена" ToolTip="Нажмите чтобы вернуться" Style="{StaticResource ButtonStyle}" Click="CancelButton_Click"/>
    </Grid>
</Page>
