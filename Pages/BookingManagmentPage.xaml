<Page x:Class="ApartmentChain.Pages.BookingManagmentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ApartmentChain.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Страница управления бронированиями" Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Мои бронирования" Grid.Row="0" FontWeight="Bold" Style="{StaticResource TextBlockStyle }"/>

        <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Left" VerticalAlignment="Center">
            <TextBlock Text="Фильтр по статусу:" Style="{StaticResource TextBlockStyle}"/>
            <ComboBox x:Name="FilterStatusComboBox" Width="150" Margin="5,0,0,0" SelectionChanged="FilterStatusComboBox_SelectionChanged"/>
            <TextBox x:Name="SearchCityTextBox" ToolTip="Поиск по городу" Margin="10,0,0,0" Style="{StaticResource TextBoxStyle}" TextChanged="SearchCityTextBox_TextChanged"/>
        </StackPanel>

        <DataGrid x:Name="BookingsDataGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="50"/>
                <DataGridTextColumn Header="Дата заезда" Binding="{Binding Arrival}" Width="150"/>
                <DataGridTextColumn Header="Дата выезда" Binding="{Binding Departure}" Width="150"/>
                <DataGridTextColumn Header="Апартамент" Binding="{Binding ApartmentAddress}" Width="200"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="120"/>
                <DataGridTextColumn Header="Общая стоимость" Binding="{Binding TotalCost}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="CancelBookingButton" Content="Отменить бронирование" Margin="0,0,10,0" Style="{StaticResource ButtonStyle}" Click="CancelBookingButton_Click"/>
            <Button x:Name="EditBookingButton" Content="Редактировать" Margin="10,0,0,0" Style="{StaticResource ButtonStyle}" Click="EditBookingButton_Click"/>
        </StackPanel>
    </Grid>
</Page>
