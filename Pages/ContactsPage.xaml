<Page x:Class="ApartmentChain.Pages.ContactsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ApartmentChain.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="700"
      Title="Страница контактов">

    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="210"/>
                <RowDefinition Height="220"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Контактная информация" Grid.Row="0" Style="{StaticResource HeaderTextBlockStyle}"/>

            <Border Grid.Row="1" Padding="10" Background="#80F5F5DC" CornerRadius="15" Width="460">
                <StackPanel>
                    <Image Source="/Resources/Logo.png" Width="150" Height="150" HorizontalAlignment="Center"/>
                    <TextBlock Text="Мы всегда рады услышать вас!" FontWeight="SemiBold" Style="{StaticResource HeaderTextBlockStyle}"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="2" Margin="0,10,0,0">
                <Border Background="#80F5F5DC" CornerRadius="15" Padding="10" Width="460">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📨 Электронная почта: " FontWeight="SemiBold" Style="{StaticResource TextBlockStyle}"/>
                        <TextBlock Text="contact@example.com" TextDecorations="Underline" Foreground="#3498DB" Style="{StaticResource TextBlockStyle}"/>
                    </StackPanel>
                </Border>
                <Border Background="#80F5F5DC" CornerRadius="15" Padding="10" Width="460" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📞 Телефон: " FontWeight="SemiBold" Style="{StaticResource TextBlockStyle}"/>
                        <TextBlock Text="+7 (123) 456-78-90" TextDecorations="Underline" Foreground="#3498DB" Style="{StaticResource TextBlockStyle}"/>
                    </StackPanel>
                </Border>
                <Border Background="#80F5F5DC" CornerRadius="15" Padding="10" Width="460" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📍 Адрес: " FontWeight="SemiBold" Style="{StaticResource TextBlockStyle}"/>
                        <TextBlock Text="г. Москва, ул. Примерная, д. 1 (М. Неизвестного)" Style="{StaticResource TextBlockStyle}"/>
                    </StackPanel>
                </Border>
                <Border Background="#80F5F5DC" CornerRadius="15" Padding="10" Width="460" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🕒 Часы работы: " FontWeight="SemiBold" Style="{StaticResource TextBlockStyle}"/>
                        <TextBlock Text="Пн - Пт 10.00 - 15.30" Style="{StaticResource TextBlockStyle}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <TextBlock Grid.Row="3" Text="Ждём вашего обращения! Мы всегда на связи." FontStyle="Italic" Foreground="#7F8C8D" Style="{StaticResource TextBlockStyle}"/>
        </Grid>
    </ScrollViewer>
</Page>