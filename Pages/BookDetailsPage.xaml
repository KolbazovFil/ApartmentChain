<Page x:Class="ApartmentChain.Pages.BookDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ApartmentChain.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="910" d:DesignWidth="825"
      Title="Детали бронирования">

    <Grid>
        <ScrollViewer x:Name="MainScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Center" Orientation="Vertical" VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal">
                    
                    <Border Background="{Binding RatingBrush}" CornerRadius="8" Padding="4">
                        <TextBlock Text="{Binding Reviews}" FontSize="16" FontWeight="Bold"/>
                    </Border>
                    <Rectangle Width="5"/>
                    
                    <Label Cursor="Hand" MouseLeftButtonDown="Label_MouseLeftButtonDown" ToolTip="Нажмите чтобы перейти к отзывам">
                        <TextBlock Text="{Binding ReviewsCountText}" TextDecorations="Underline"/>
                    </Label>
                    
                    <TextBlock Text="{Binding Countries}" Style="{StaticResource TextBlockStyle}"/>
                    <TextBlock Text="{Binding Cities}" Style="{StaticResource TextBlockStyle}"/>
                    <TextBlock Text="{Binding Address}" Style="{StaticResource TextBlockStyle}"/>
                    <Rectangle Width="80"/>
                    <TextBlock Text="{Binding Price, StringFormat=Цена: {0} ₽ в сутки}" FontWeight="Bold" Style="{StaticResource TextBlockStyle}"/>
                </StackPanel>
                <Rectangle Height="5"/>

                <Border DataContext="{Binding PhotosViewModel}" HorizontalAlignment="Center" Width="820" Height="450">
                    <Grid>
                        <Image Source="{Binding CurrentPhoto}" Stretch="Fill"/>
                        <Button x:Name="PrevPhotoButton" Content="◀" Command="{Binding PrevPhotoCommand}" HorizontalAlignment="Left" Style="{StaticResource CommandButtonStyle}"/>
                        <Button x:Name="NextPhotoButton" Content="▶" Command="{Binding NextPhotoCommand}" HorizontalAlignment="Right" Style="{StaticResource CommandButtonStyle}"/>
                    </Grid>
                </Border>
                <Rectangle Height="10" VerticalAlignment="Top" HorizontalAlignment="Center"/>

                <StackPanel Orientation="Horizontal">

                    <DatePicker Name="ArivalDataPicker" ToolTip="Выберите дату заезда" Width="150" Style="{StaticResource DatePickerStyle}">
                        <DatePicker.Resources>
                            <Style TargetType="DatePickerTextBox">
                                <Setter Property="Text" Value="Заезд"/>
                            </Style>
                        </DatePicker.Resources>
                    </DatePicker>

                    <Rectangle Width="10"/>

                    <DatePicker Name="DepartureDataPicker" ToolTip="Выберите дату выезда" Width="150" Style="{StaticResource DatePickerStyle}">
                        <DatePicker.Resources>
                            <Style TargetType="DatePickerTextBox">
                                <Setter Property="Text" Value="Выезд"/>
                            </Style>
                        </DatePicker.Resources>
                    </DatePicker>

                    <Rectangle Width="10"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Width="250">
                            <TextBlock Text="Кол-во людей: " VerticalAlignment="Center" Style="{StaticResource TextBlockStyle}"/>
                            <ComboBox x:Name="PeopleCountComboBox" ToolTip="Выберите количество людей" VerticalContentAlignment="Center" Width="40" Height="40" FontFamily="Segoe UI" FontSize="14">
                                <ComboBoxItem Content="1"/>
                                <ComboBoxItem Content="2"/>
                                <ComboBoxItem Content="3"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                    <Button Name="ConfirmBookingButton" Content="Подтвердить бронирование" ToolTip="Нажмите для подтверждения бронирования" Width="250" Height="50" Style="{StaticResource ButtonStyle}" HorizontalAlignment="Right" Click="ConfirmBookingButton_Click"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Height="50" HorizontalAlignment="Left">
                    <TextBlock Name="ReviewsTextBlock" Text="ОТЗЫВЫ" Height="20" Width="318" Style="{StaticResource TextBlockStyle}" VerticalAlignment="Bottom" FontWeight="Bold"/>
                    <TextBlock Text="Метод оплаты: " VerticalAlignment="Center" Style="{StaticResource TextBlockStyle}"/>
                    <ComboBox x:Name="MethodOfPayComboBox" ToolTip="Выберите метод оплаты" VerticalContentAlignment="Center" Width="130" Height="40" FontFamily="Segoe UI" FontSize="14"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <StackPanel Orientation="Horizontal">
                        <ListBox x:Name="ReviewsListBox" Width="420" Height="310" ItemsSource="{Binding ReviewsList}" Background="Beige" BorderBrush="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderThickness="1" BorderBrush="Bisque" Width="389" MaxWidth="420">
                                        <StackPanel Orientation="Vertical" Width="Auto">
                                            <TextBlock Text="{Binding User}" TextDecorations="Underline"/>
                                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Rating, StringFormat=Оценка: {0}}" FontStyle="Italic"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <Rectangle Width="5"/>

                    <Button Name="AddReviewButton" ToolTip="Нажмите чтобы оставить отзыв" Content="Отзовитесь" VerticalAlignment="Bottom" Width="100" Style="{StaticResource ButtonStyle}" Click="AddReviewButton_Click"/>


                    <StackPanel x:Name="NewReviewPanel" Orientation="Vertical" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Рейтинг: " Style="{StaticResource TextBlockStyle}"/>
                            <ComboBox x:Name="RatingComboBox" ToolTip="Выберите оценку" Width="35" FontFamily="Segoe UI" FontSize="14">
                                <ComboBoxItem Content="1"/>
                                <ComboBoxItem Content="2"/>
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="4"/>
                                <ComboBoxItem Content="5"/>
                            </ComboBox>
                        </StackPanel>
                        <TextBlock Text="Ваш отзыв:" Style="{StaticResource TextBlockStyle}" HorizontalAlignment="Left"/>
                        <TextBox x:Name="NewReviewTextBox" VerticalContentAlignment="Top" Height="200" TextWrapping="Wrap" Width="335" AcceptsReturn="True" Style="{StaticResource TextBoxStyle}"/>
                        <Rectangle Height="8"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Отмена" ToolTip="Нажмите чтобы отменить отзыв" Width="80" Style="{StaticResource ButtonStyle}" Click="CancelNewReview_Click"/>
                            <Rectangle Width="10"/>
                            <Button Content="Отправить" ToolTip="Нажмите чтобы сохранить отзыв" Width="80" Style="{StaticResource ButtonStyle}" Click="SendNewReview_Click"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
