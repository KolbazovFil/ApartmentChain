<Page x:Class="ApartmentChain.Pages.BookDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ApartmentChain.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="910" d:DesignWidth="825"
      Title="Страница деталей бронирования">

    <Grid>
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Center" Orientation="Vertical" VerticalAlignment="Top">
                <TextBlock Text="Бронирование" Style="{StaticResource HeaderTextBlockStyle}"/>
                
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Border Background="{Binding RatingBrush}" CornerRadius="8" Padding="3">
                        <TextBlock Text="{Binding Reviews}" FontWeight="Bold" Style="{StaticResource TextBlockStyle}"/>
                    </Border>

                    <Label Cursor="Hand" ToolTip="Нажмите чтобы перейти к отзывам" Margin="4,0,0,0" VerticalAlignment="Bottom" MouseLeftButtonDown="Label_MouseLeftButtonDown">
                        <TextBlock Text="{Binding ReviewsCountText}" FontSize="12" TextDecorations="Underline" Style="{StaticResource TextBlockStyle}"/>
                    </Label>
                    
                    <TextBlock Text="{Binding Countries}" Style="{StaticResource TextBlockStyle}"/>
                    <TextBlock Text="{Binding Cities}" Style="{StaticResource TextBlockStyle}"/>
                    <TextBlock Text="{Binding Address}" Style="{StaticResource TextBlockStyle}"/>
                    <Rectangle Width="75"/>
                    <TextBlock Text="{Binding Price, StringFormat=Цена: {0} ₽ в сутки}" FontWeight="Bold" Style="{StaticResource TextBlockStyle}"/>
                </StackPanel>
                
                <Border DataContext="{Binding PhotosViewModel}" Margin="0,5,0,0" HorizontalAlignment="Center" Width="820" Height="450">
                    <Grid>
                        <Image Source="{Binding CurrentPhoto}" Stretch="Fill"/>
                        <Button x:Name="PrevPhotoButton" Content="◀" HorizontalAlignment="Left" Command="{Binding PrevPhotoCommand}" Style="{StaticResource CommandButtonStyle}"/>
                        <Button x:Name="NextPhotoButton" Content="▶" HorizontalAlignment="Right" Command="{Binding NextPhotoCommand}" Style="{StaticResource CommandButtonStyle}"/>
                    </Grid>
                </Border>
                
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <DatePicker Name="ArivalDataPicker" ToolTip="Выберите дату заезда" Width="150" Style="{StaticResource DatePickerStyle}">
                        <DatePicker.Resources>
                            <Style TargetType="DatePickerTextBox">
                                <Setter Property="Text" Value="Заезд"/>
                            </Style>
                        </DatePicker.Resources>
                    </DatePicker>

                    <DatePicker Name="DepartureDataPicker" ToolTip="Выберите дату выезда" Width="150" Margin="10,0,0,0" Style="{StaticResource DatePickerStyle}">
                        <DatePicker.Resources>
                            <Style TargetType="DatePickerTextBox">
                                <Setter Property="Text" Value="Выезд"/>
                            </Style>
                        </DatePicker.Resources>
                    </DatePicker>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                        <StackPanel Orientation="Horizontal" Width="300">
                            <TextBlock Text="Кол-во людей: " VerticalAlignment="Center" Style="{StaticResource TextBlockStyle}"/>
                            <ComboBox x:Name="PeopleCountComboBox" ToolTip="Выберите количество людей которые будут проживать в апартаментах" Width="40" Style="{StaticResource ComboBoxStyle}">
                                <ComboBoxItem Content="1"/>
                                <ComboBoxItem Content="2"/>
                                <ComboBoxItem Content="3"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                    <Button Name="ConfirmBookingButton" Content="Забронировать" ToolTip="Нажмите для подтверждения бронирования" Height="50" Style="{StaticResource ButtonStyle}" Click="ConfirmBookingButton_Click"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Height="50">
                    <TextBlock Text="ОТЗЫВЫ" Width="318" VerticalAlignment="Bottom" FontWeight="Bold" Style="{StaticResource TextBlockStyle}"/>
                    <TextBlock Text="Метод оплаты: " Style="{StaticResource TextBlockStyle}"/>
                    <ComboBox x:Name="MethodOfPayComboBox" ToolTip="Выберите метод оплаты" Width="150" Style="{StaticResource ComboBoxStyle}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <StackPanel Orientation="Horizontal">
                        <ListBox x:Name="ReviewsListBox" Width="420" Height="270" VerticalAlignment="Top" ItemsSource="{Binding ReviewsList}" Background="Bisque" BorderBrush="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderThickness="1" BorderBrush="BurlyWood"  Width="389" MaxWidth="420">
                                        <StackPanel Orientation="Vertical" Width="Auto">
                                            <TextBlock Text="{Binding User}" TextDecorations="Underline"/>
                                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Rating, StringFormat=Оценка: {0}}" FontStyle="Italic"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <Button Name="AddReviewButton" ToolTip="Нажмите чтобы оставить отзыв" Content="Отзовитесь и Вы" Margin="10,0,0,0" VerticalAlignment="Bottom" Width="150" Style="{StaticResource ButtonStyle}" Click="AddReviewButton_Click"/>

                    <StackPanel x:Name="NewReviewPanel" Margin="10,0,0,0" Orientation="Vertical" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Рейтинг: " Style="{StaticResource TextBlockStyle}"/>
                            <ComboBox x:Name="RatingComboBox" ToolTip="Выберите оценку" Width="40" Height="25" Style="{StaticResource ComboBoxStyle}">
                                <ComboBoxItem Content="1"/>
                                <ComboBoxItem Content="2"/>
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="4"/>
                                <ComboBoxItem Content="5"/>
                            </ComboBox>
                        </StackPanel>
                        <TextBlock Text="Ваш отзыв:" HorizontalAlignment="Left" Style="{StaticResource TextBlockStyle}"/>
                        <TextBox x:Name="NewReviewTextBox" VerticalContentAlignment="Top" Height="155" TextWrapping="Wrap" Width="390" AcceptsReturn="True" Style="{StaticResource TextBoxStyle}"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                            <Button Content="Отправить" ToolTip="Нажмите чтобы сохранить отзыв" Width="115" Style="{StaticResource ButtonStyle}" Click="SendNewReview_Click"/>
                            <Button Content="Отмена" ToolTip="Нажмите чтобы отменить отзыв" Width="115" Margin="10,0,0,0" Style="{StaticResource ButtonStyle}" Click="CancelNewReview_Click"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
